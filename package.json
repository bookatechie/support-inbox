{
  "name": "support-inbox",
  "version": "0.1.1",
  "description": "Modern real-time customer support shared inbox",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bookatechie/support-inbox.git"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "dev:client": "cd src/client && npm run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "cd src/client && npm run build",
    "start": "node dist/server/index.js",
    "build:standalone": "npm run build && pkg dist/server/index.js -t node20-linux-x64 --assets 'dist/client/**/*' -o support-inbox",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/server/",
    "clean": "rm -rf dist",
    "deploy": "git pull && npm run build && pm2 restart support-inbox"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.927.0",
    "@fastify/compress": "^8.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/static": "^8.0.2",
    "@types/pg": "^8.15.6",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.1",
    "email-forward-parser": "^1.7.2",
    "email-reply-parser": "^2.3.5",
    "fastify": "^5.2.0",
    "heic-convert": "^2.1.0",
    "imap-simple": "^5.1.0",
    "mailparser": "^3.9.4",
    "nodemailer": "^6.9.9",
    "pg": "^8.16.3"
  },
  "devDependencies": {
"@types/bcryptjs": "^2.4.6",
    "@types/heic-convert": "^2.1.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^6.4.21",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "pino-pretty": "^13.1.2",
    "pkg": "^5.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
